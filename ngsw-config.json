{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|webp|avif|otf|ttf|woff|woff2)",
          "/assets/**",
          "/*"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "google-fonts-styles",
      "urls": [
        "https://fonts.googleapis.com/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "7d",
        "timeout": "3s"
      }
    },
    {
      "name": "google-fonts-webfonts",
      "urls": [
        "https://fonts.gstatic.com/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 30,
        "maxAge": "30d"
      }
    }
  ]
}
